---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Forzar el uso del dominio de producción para que LinkedIn y Facebook puedan extraer el preview
const shareUrl = new URL(Astro.url.pathname, Astro.site || 'https://salvadoribarra.tech').toString();
---

<MainLayout 
  title={`${post.data.title} | Salvador Ibarra`} 
  description={post.data.description}
  image={post.data.image ? `/assets/posts/${post.data.image}` : undefined}
  imageAlt={post.data.imageAlt || post.data.title}
  type="article"
>
  <article class="max-w-4xl mx-auto py-20 px-6 min-h-screen">
    
    {/* Navigation */}
    <div class="mb-12">
      <a href="/insights" class="inline-flex items-center text-teal font-medium hover:text-white transition-colors group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Insights
      </a>
    </div>

    <div class="bg-[#1E293B]/50 border border-teal/20 rounded-2xl overflow-hidden shadow-2xl">
      {/* Header */}
      <header class="p-8 md:p-12 border-b border-white/10 bg-[#020617]/50">
        <div class="space-y-4 max-w-3xl">
          <span class="text-sm text-teal font-mono uppercase tracking-widest font-bold">
            {post.data.pubDate.toLocaleDateString('en-US', { day:'numeric', month: 'long', year: 'numeric' })}
          </span>
          <h1 class="text-3xl md:text-5xl text-white font-bold leading-tight font-sans">
            {post.data.title}
          </h1>
          <p class="text-xl text-slate-400 mt-4 leading-relaxed">
            {post.data.description}
          </p>
        </div>
      </header>

      {/* Content */}
      <div class="p-8 md:p-12 overflow-visible prose prose-invert prose-lg max-w-none font-sans text-slate-50
        prose-headings:text-teal prose-headings:font-bold 
        prose-p:text-slate-50 prose-p:leading-relaxed
        prose-li:text-slate-50
        prose-strong:text-teal prose-strong:font-bold
        prose-a:text-teal prose-a:no-underline hover:prose-a:underline
        prose-blockquote:border-l-teal prose-blockquote:text-slate-300 prose-blockquote:bg-white/5 prose-blockquote:py-2 prose-blockquote:px-4 prose-blockquote:rounded-r
      ">
        {post.data.image && (
          <div class="mb-12 rounded-xl overflow-hidden bg-[#020617] flex justify-center border border-white/10 w-full">
            <img 
              src={`/assets/posts/${post.data.image}`} 
              alt={post.data.imageAlt || post.data.title}
              class="w-full max-h-[60vh] object-contain"
            />
          </div>
        )}

        <Content />
      </div>
      
      {/* Footer / Social Share */}
      <footer class="p-8 md:p-12 border-t border-white/10 bg-[#020617]/50 mt-12">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="text-slate-300 font-medium">Share this article:</div>
          <div class="flex items-center space-x-6">
            {/* LinkedIn */}
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-teal transition-colors" aria-label="Share on LinkedIn">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            {/* Facebook */}
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-teal transition-colors" aria-label="Share on Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M14 13.5h2.5l1-4H14v-2c0-1.03 0-2 2-2h1.5V2.14c-.326-.043-1.557-.14-2.857-.14C11.928 2 10 3.657 10 6.7v2.8H7v4h3V22h4v-8.5z" />
              </svg>
            </a>
            {/* X (Twitter) */}
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-teal transition-colors" aria-label="Share on X">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 24.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            {/* WhatsApp */}
            <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(post.data.title + ' - ' + shareUrl)}`} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-teal transition-colors" aria-label="Share on WhatsApp">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M11.904 0C5.339 0 0 5.334 0 11.897c0 2.13.562 4.258 1.634 6.104L.073 24l6.195-1.61c1.802.977 3.842 1.496 5.862 1.496 6.565 0 11.904-5.334 11.904-11.896C24.034 5.334 18.696 0 11.904 0zm0 21.84c-1.782 0-3.528-.475-5.06-1.374l-.36-.214-3.766.982.999-3.664-.236-.375c-.987-1.579-1.509-3.415-1.509-5.297 0-5.378 4.372-9.743 9.754-9.743 5.383 0 9.755 4.365 9.755 9.743 0 5.384-4.372 9.743-9.755 9.743zm5.35-7.31c-.294-.148-1.737-.858-2.006-.957-.27-.098-.466-.148-.661.148-.196.294-.755.957-.926 1.152-.172.196-.343.22-.637.073-2.05-.989-3.435-2.316-4.226-3.655-.173-.294.17-.282.457-.852.098-.196.049-.367-.024-.515-.073-.148-.661-1.595-.907-2.183-.242-.572-.486-.495-.661-.504-.172-.008-.367-.008-.564-.008-.196 0-.514.073-.784.367s-1.03 1.006-1.03 2.454 1.054 2.846 1.201 3.042c.148.196 2.073 3.167 5.02 4.437.7.3 1.246.48 1.671.614.704.223 1.345.19 1.848.115.565-.084 1.737-.71 1.983-1.396.244-.686.244-1.274.171-1.396-.073-.122-.27-.196-.564-.343z" />
              </svg>
            </a>
          </div>
        </div>

        <div class="mt-8 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-6">
          <a href="/insights" class="inline-flex items-center text-teal font-medium hover:text-white transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            ← Volver a Insights
          </a>

          {post.data.linkedinUrl && (
            <a href={post.data.linkedinUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-3 bg-[#0077b5] text-white font-bold rounded shadow-lg hover:bg-[#0077b5]/90 transition-all hover:scale-105 active:scale-95">
              <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              Discuss on LinkedIn
            </a>
          )}
        </div>
      </footer>
    </div>
  </article>
</MainLayout>

<style>
  /* Global prose adjustments to maintain teal thematic accents */
  :global(.prose strong) {
    color: #14B8A6 !important;
    font-weight: 700 !important;
  }
</style>
