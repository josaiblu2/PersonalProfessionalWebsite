---
import { getCollection } from 'astro:content';

const posts = await getCollection('insights');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<section id="insights" class="py-20 px-6">
  <div class="max-w-7xl mx-auto space-y-12">
    <div class="space-y-4">
      <h2 class="text-xs font-mono text-teal tracking-widest uppercase">Latest Thoughts</h2>
      <h3 class="text-4xl rounded md:text-5xl text-white font-bold">Insights & Publications</h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedPosts.map((post) => (
        <article class="bg-navy-light/50 border border-teal/20 rounded-xl overflow-hidden hover:border-teal/50 transition-all group flex flex-col h-full">
            {post.data.image && (
                <a 
                    href={`/insights/${post.slug}`}
                    class="h-48 overflow-hidden relative w-full text-left cursor-pointer focus:outline-none focus:ring-2 focus:ring-teal/50 bg-[#020617] block"
                >
                    <img 
                        src={`/assets/posts/${post.data.image}`} 
                        alt={post.data.title}
                        class="w-full h-full object-contain transform group-hover:scale-105 transition-transform duration-500"
                    />
                    <div class="absolute inset-0 bg-navy/20 group-hover:bg-transparent transition-colors"></div>
                </a>
            )}
            
            <div class="p-6 flex flex-col flex-1">
                <div class="flex justify-between items-start mb-4">
                    <span class="text-xs text-slate/60 font-mono">
                        {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
                    </span>
                </div>
                
                <h4 class="text-xl text-white font-bold mb-3 group-hover:text-teal transition-colors">
                    <a 
                        href={`/insights/${post.slug}`}
                        class="text-left hover:underline decoration-teal underline-offset-4 focus:outline-none"
                    >
                        {post.data.title}
                    </a>
                </h4>
                
                <p class="text-slate text-sm leading-relaxed mb-6 flex-1">
                    {post.data.description}
                </p>
                
                <a 
                    href={`/insights/${post.slug}`}
                    class="inline-flex items-center text-teal font-bold text-sm hover:text-white transition-colors cursor-pointer"
                >
                    Read More 
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </a>
            </div>
        </article>
      ))}
    </div>
  </div>

</section>
